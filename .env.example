# Hugging Face token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxx

# Tool-capable model on the HF router (provider can be pinned with :provider)
MODEL_ID=moonshotai/Kimi-K2-Instruct

# Allow shell commands to run without per-command confirmation (true/false).
# Leave false while you trust the agent — it asks before every shell command.
AUTO_APPROVE=false
