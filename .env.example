# Hugging Face token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxx

# Tool-capable model on the HF router (provider can be pinned with :provider)
MODEL_ID=moonshotai/Kimi-K2-Instruct

# --- Qdrant: incident memory (hybrid search over past resolved incidents) ---
# Managed cluster endpoint (port 6333) and a read-write Database API key.
QDRANT_URL=https://<cluster-id>.<region>.<provider>.cloud.qdrant.io:6333
QDRANT_API_KEY=
# Collection name (created by setup_qdrant.py). Override only if you want.
QDRANT_COLLECTION=sre-incidents

# Optional: also archive each resolved incident to a HF Storage Bucket as
# incidents/<id>.json (durable, S3-like copy). Leave empty to use Qdrant only.
# Format: "username/bucket-name". Uses HF_TOKEN above (write scope on namespace).
HF_INCIDENTS_BUCKET=

# When true, auto-run ONLY vetted read-only commands (kubectl get/describe/logs,
# curl, dig, journalctl, df, ps, ...). Anything that could mutate state still
# prompts — so it's declined in a non-interactive run. It does NOT mean "run
# anything". Leave false to confirm every command.
AUTO_APPROVE=false
